<header class="vector-header mw-header no-font-mode-scale">
	<div class="vector-header-start">
		<nav class="vector-main-menu-landmark" aria-label="{{msg-vector-site-nav-label}}">
			{{>MainMenuDropdown}}
		</nav>
		{{#data-logos}}{{>Logo}}{{/data-logos}}
	</div>
	<div class="vector-header-search">
		{{#data-search-box}}{{>SearchBox}}{{/data-search-box}}
	</div>
	<div class="vector-header-end">
		{{#data-search-toggle-button}}{{>Button}}{{/data-search-toggle-button}}
		{{#data-vector-user-links}}{{>UserLinks}}{{/data-vector-user-links}}
	</div>
</header>
