{
	"name": "ubuntu/mediawiki-ubuntu-skin",
	"type": "mediawiki-skin",
	"description": "Ubuntu MediaWiki skin based on Vector 2022",
	"keywords": [
		"wiki",
		"MediaWiki",
		"skin"
	],
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Trevor Parscal"
		},
		{
			"name": "Roan Kattouw"
		}
	],
	"support": {
		"source": "https://github.com/ubuntu/ubuntu-mediawiki-skin"
	},
	"require": {
		"composer/installers": ">1.0.12"
	},
	"extra": {
		"branch-alias": {
			"dev-main": "1.x-dev"
		},
		"installer-name": "Ubuntu"
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": "48.0.0",
		"mediawiki/mediawiki-phan-config": "0.20.0",
		"mediawiki/minus-x": "1.1.3",
		"php-parallel-lint/php-console-highlighter": "1.0.0",
		"php-parallel-lint/php-parallel-lint": "1.4.0"
	},
	"scripts": {
		"fix": [
			"minus-x fix .",
			"phpcbf"
		],
		"test": [
			"parallel-lint . --exclude node_modules --exclude vendor",
			"@phpcs",
			"minus-x check ."
		],
		"test:size": "@composer -d ../../ phpunit skins/Vector/tests/phpunit/structure/BundleSizeTest.php",
		"phan": "phan -d . --long-progress-bar",
		"phpcs": "phpcs -sp --cache"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
